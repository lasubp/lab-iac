pm_api_url          = "https://pve.example.com:8006/api2/json"
pm_api_token_id     = "terraform@pve!lab"
pm_api_token_secret = "CHANGE_ME"
pm_tls_insecure     = true

target_node            = "pve"
clone_storage          = "local-lvm"
opnsense_vm_name       = "lab-opnsense"
opnsense_vmid          = 2000
ubuntu_vmid_base       = 2100
ubuntu_vmid_stride     = 10
ubuntu_template_name   = "ubuntu-2404-cloudinit-template"
opnsense_template_name = "opnsense-template"
ssh_public_key_file    = "/home/your-user/.ssh/id_ed25519.pub"

wan_bridge              = "vmbr1"
enable_proxmox_firewall = true
ubuntu_network_model    = "virtio"
opnsense_network_model  = "virtio"
hub_network_name        = "net1"
opnsense_internal_network_order = ["net1", "net2", "net3", "net4", "net5"]

dns_servers  = ["1.1.1.1", "8.8.8.8"]
searchdomain = "lab.local"

ubuntu_cores     = 2
ubuntu_memory    = 2048
ubuntu_disk_size = "20G"

opnsense_cores     = 2
opnsense_memory    = 4096
opnsense_disk_size = "32G"

